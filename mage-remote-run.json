{
  "$schema": "https://mage-remote-run.muench.dev/config.schema.json",
  "commands": [
    {
      "name": "amasty company",
      "description": "Amasty Company Account — CRUD, credit, customer assignment, addresses",
      "summary": "Company Account B2B management"
    },
    {
      "name": "amasty company credit",
      "description": "Company credit management",
      "summary": "Get and update company credit lines"
    },
    {
      "name": "amasty company customer",
      "description": "Customer-company assignment",
      "summary": "Assign or remove customers from a company"
    },
    {
      "name": "amasty company address",
      "description": "Company address management",
      "summary": "List, get, create, and delete company addresses"
    },
    {
      "name": "amasty quote",
      "description": "Amasty Request for Quote (RFQ) — quotes and quote carts",
      "summary": "Request for Quote B2B management"
    },
    {
      "name": "amasty quote note",
      "description": "Quote-level notes (customer and admin)",
      "summary": "Add notes to a quote"
    },
    {
      "name": "amasty quote item-note",
      "description": "Quote item-level notes (customer and admin)",
      "summary": "Add notes to a quote item"
    },
    {
      "name": "amasty quote cart",
      "description": "Quote cart operations",
      "summary": "Create, update, cancel, and submit quote carts"
    },
    {
      "name": "amasty quote cart items",
      "description": "Quote cart item management",
      "summary": "List, add, update, and remove items from a quote cart"
    },
    {
      "name": "amasty quote guest-cart",
      "description": "Guest quote cart operations",
      "summary": "Guest quote cart create, submit, and item management"
    },
    {
      "name": "amasty quote guest-cart items",
      "description": "Guest quote cart item management",
      "summary": "List, add, update, and remove guest quote cart items"
    },
    {
      "name": "amasty quickorder",
      "description": "Amasty Quick Order — product search by name or SKU",
      "summary": "Quick Order product search"
    },
    {
      "name": "amasty storecredit",
      "description": "Amasty Store Credit — apply, cancel, and check balance",
      "summary": "Store Credit management"
    },
    {
      "name": "amasty attachment",
      "description": "Amasty Product Attachments — get and manage attachment files",
      "summary": "Product Attachment management"
    },
    {
      "name": "amasty wishlist",
      "description": "Amasty Multiple Wishlists — create and manage customer wishlists",
      "summary": "Multiple Wishlist management"
    },

    {
      "name": "amasty company get",
      "method": "GET",
      "endpoint": "/V1/amcompany/company/:companyId",
      "description": "Get company data by ID",
      "options": {
        "companyId": {
          "required": true,
          "description": "Company ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company create",
      "method": "POST",
      "endpoint": "/V1/amcompany/company",
      "description": "Create a new company",
      "body": {
        "company": {
          "company_name": "${company_name}",
          "company_email": "${company_email}",
          "status": "${status}",
          "legal_name": "${legal_name}",
          "vat_tax_id": "${vat_tax_id}",
          "reseller_id": "${reseller_id}",
          "street": "${street}",
          "city": "${city}",
          "country_id": "${country_id}",
          "region": "${region}",
          "region_id": "${region_id}",
          "postcode": "${postcode}",
          "telephone": "${telephone}",
          "manager_id": "${manager_id}"
        }
      },
      "options": {
        "company_name": {
          "required": true,
          "description": "Company name",
          "type": "string"
        },
        "company_email": {
          "required": true,
          "description": "Company email address",
          "type": "string"
        },
        "status": {
          "required": true,
          "description": "Company status",
          "default": "1",
          "choices": [
            { "name": "Pending Approval", "value": "0" },
            { "name": "Active", "value": "1" },
            { "name": "Rejected", "value": "2" },
            { "name": "Blocked", "value": "3" }
          ]
        },
        "legal_name": {
          "required": true,
          "description": "Legal name of the company",
          "type": "string",
          "default": null
        },
        "vat_tax_id": {
          "required": true,
          "description": "VAT / tax ID",
          "type": "string",
          "default": null
        },
        "reseller_id": {
          "required": false,
          "description": "Reseller ID",
          "type": "string",
          "default": null
        },
        "street": {
          "required": true,
          "description": "Street address",
          "type": "string",
          "default": null
        },
        "city": {
          "required": true,
          "description": "City",
          "type": "string",
          "default": null
        },
        "country_id": {
          "required": true,
          "description": "Two-letter country code (e.g. US)",
          "type": "string",
          "default": null
        },
        "region": {
          "required": false,
          "description": "Region / state name",
          "type": "string",
          "default": null
        },
        "region_id": {
          "required": true,
          "description": "Region ID",
          "type": "number",
          "default": null
        },
        "postcode": {
          "required": true,
          "description": "Postal code",
          "type": "string",
          "default": null
        },
        "telephone": {
          "required": true,
          "description": "Phone number",
          "type": "string",
          "default": null
        },
        "manager_id": {
          "required": true,
          "description": "Customer ID of the company manager",
          "type": "number",
          "default": null
        }
      }
    },
    {
      "name": "amasty company update",
      "method": "PUT",
      "endpoint": "/V1/amcompany/company/:companyId",
      "description": "Update an existing company",
      "body": {
        "company": {
          "company_name": "${company_name}",
          "company_email": "${company_email}",
          "status": "${status}",
          "legal_name": "${legal_name}",
          "vat_tax_id": "${vat_tax_id}",
          "reseller_id": "${reseller_id}",
          "street": "${street}",
          "city": "${city}",
          "country_id": "${country_id}",
          "region": "${region}",
          "region_id": "${region_id}",
          "postcode": "${postcode}",
          "telephone": "${telephone}",
          "manager_id": "${manager_id}"
        }
      },
      "options": {
        "companyId": {
          "required": true,
          "description": "Company ID",
          "type": "string"
        },
        "company_name": {
          "required": false,
          "description": "Company name",
          "type": "string",
          "default": null
        },
        "company_email": {
          "required": false,
          "description": "Company email address",
          "type": "string",
          "default": null
        },
        "status": {
          "required": false,
          "description": "Company status",
          "default": null,
          "choices": [
            { "name": "Pending Approval", "value": "0" },
            { "name": "Active", "value": "1" },
            { "name": "Rejected", "value": "2" },
            { "name": "Blocked", "value": "3" }
          ]
        },
        "legal_name": {
          "required": false,
          "description": "Legal name of the company",
          "type": "string",
          "default": null
        },
        "vat_tax_id": {
          "required": false,
          "description": "VAT / tax ID",
          "type": "string",
          "default": null
        },
        "reseller_id": {
          "required": false,
          "description": "Reseller ID",
          "type": "string",
          "default": null
        },
        "street": {
          "required": false,
          "description": "Street address",
          "type": "string",
          "default": null
        },
        "city": {
          "required": false,
          "description": "City",
          "type": "string",
          "default": null
        },
        "country_id": {
          "required": false,
          "description": "Two-letter country code (e.g. US)",
          "type": "string",
          "default": null
        },
        "region": {
          "required": false,
          "description": "Region / state name",
          "type": "string",
          "default": null
        },
        "region_id": {
          "required": false,
          "description": "Region ID",
          "type": "number",
          "default": null
        },
        "postcode": {
          "required": false,
          "description": "Postal code",
          "type": "string",
          "default": null
        },
        "telephone": {
          "required": false,
          "description": "Phone number",
          "type": "string",
          "default": null
        },
        "manager_id": {
          "required": false,
          "description": "Customer ID of the company manager",
          "type": "number",
          "default": null
        }
      }
    },
    {
      "name": "amasty company delete",
      "method": "DELETE",
      "endpoint": "/V1/amcompany/company/:companyId",
      "description": "Delete a company by ID",
      "options": {
        "companyId": {
          "required": true,
          "description": "Company ID",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty company credit get",
      "method": "GET",
      "endpoint": "/V1/amcompany/credit/:companyId",
      "description": "Get credit data for a company",
      "options": {
        "companyId": {
          "required": true,
          "description": "Company ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company credit update",
      "method": "PUT",
      "endpoint": "/V1/amcompany/credit/:id",
      "description": "Update company credit (limit, balance, currency)",
      "options": {
        "id": {
          "required": true,
          "description": "Credit record ID",
          "type": "string"
        },
        "credit_limit": {
          "required": false,
          "description": "Credit limit amount",
          "type": "string"
        },
        "currency_code": {
          "required": false,
          "description": "Currency code (e.g. USD)",
          "type": "string"
        },
        "available_credit": {
          "required": false,
          "description": "Available credit balance",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty company customer assign",
      "method": "POST",
      "endpoint": "/V1/amcompany/customer/:companyId",
      "description": "Assign a customer to a company",
      "body": {
        "customerId": "${customerId}"
      },
      "options": {
        "companyId": {
          "required": true,
          "description": "Company ID to assign the customer to",
          "type": "string"
        },
        "customerId": {
          "required": true,
          "description": "Customer ID to assign to the company",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company customer remove",
      "method": "DELETE",
      "endpoint": "/V1/amcompany/customer/:customerId",
      "description": "Remove a customer from their current company",
      "options": {
        "customerId": {
          "required": true,
          "description": "Customer ID to remove from company",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty company address list",
      "method": "GET",
      "endpoint": "/V1/amcompany/address/:companyId",
      "description": "List all addresses for a company (admin)",
      "options": {
        "companyId": {
          "required": true,
          "description": "Company ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company address list-by-customer",
      "method": "GET",
      "endpoint": "/V1/amcompany/addressbycustomer/:customerId/list",
      "description": "List company addresses for a specific customer (admin)",
      "options": {
        "customerId": {
          "required": true,
          "description": "Customer ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company address list-mine",
      "method": "GET",
      "endpoint": "/V1/amcompany/addressbycustomer/me/list",
      "description": "List company addresses for the current authenticated customer"
    },
    {
      "name": "amasty company address get-by-customer",
      "method": "GET",
      "endpoint": "/V1/amcompany/addressbycustomer/:customerId/:addressId",
      "description": "Get a specific company address for a customer (admin)",
      "options": {
        "customerId": {
          "required": true,
          "description": "Customer ID",
          "type": "string"
        },
        "addressId": {
          "required": true,
          "description": "Address ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company address get-mine",
      "method": "GET",
      "endpoint": "/V1/amcompany/addressbycustomer/me/:addressId",
      "description": "Get a specific company address for the current customer",
      "options": {
        "addressId": {
          "required": true,
          "description": "Address ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company address create-mine",
      "method": "POST",
      "endpoint": "/V1/amcompany/addressbycustomer/me",
      "description": "Create a new company address for the current customer",
      "options": {
        "firstname": {
          "required": true,
          "description": "First name",
          "type": "string"
        },
        "lastname": {
          "required": true,
          "description": "Last name",
          "type": "string"
        },
        "street": {
          "required": true,
          "description": "Street address",
          "type": "string"
        },
        "city": {
          "required": true,
          "description": "City",
          "type": "string"
        },
        "country_id": {
          "required": true,
          "description": "Two-letter country code (e.g. US)",
          "type": "string"
        },
        "postcode": {
          "required": true,
          "description": "Postal code",
          "type": "string"
        },
        "telephone": {
          "required": true,
          "description": "Phone number",
          "type": "string"
        },
        "region": {
          "required": false,
          "description": "Region / state name",
          "type": "string"
        },
        "region_id": {
          "required": false,
          "description": "Region ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty company address delete-mine",
      "method": "DELETE",
      "endpoint": "/V1/amcompany/addressbycustomer/me/:addressId",
      "description": "Delete a company address for the current customer",
      "options": {
        "addressId": {
          "required": true,
          "description": "Address ID",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty quote get",
      "method": "GET",
      "endpoint": "/V1/amasty_quote/:quoteId",
      "description": "Get a quote by ID",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote approve",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/approve/:quoteId",
      "description": "Approve a quote (admin)",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID to approve",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote expire",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/expire/:quoteId",
      "description": "Expire a quote (admin)",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID to expire",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote update-remark",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/updateRemark",
      "description": "Update the admin remark on a quote",
      "body": {
        "quoteId": "${quoteId}",
        "remark": "${remark}"
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID",
          "type": "string"
        },
        "remark": {
          "required": true,
          "description": "Admin remark text",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote check-email",
      "method": "GET",
      "endpoint": "/V1/amasty_quote/isEmailAvailable/:customerEmail",
      "description": "Check if a customer email is available for a guest quote",
      "options": {
        "customerEmail": {
          "required": true,
          "description": "Customer email address to check",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty quote note customer",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/quote/note/customer/:quoteId",
      "description": "Add or update a customer note on a quote",
      "body": {
        "note": "${note}"
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID",
          "type": "string"
        },
        "note": {
          "required": true,
          "description": "Note text",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote note admin",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/quote/note/admin/:quoteId",
      "description": "Add or update an admin note on a quote",
      "body": {
        "note": "${note}"
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID",
          "type": "string"
        },
        "note": {
          "required": true,
          "description": "Note text",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote item-note customer",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/quote_item/note/customer/:quoteId",
      "description": "Add or update a customer note on a quote item",
      "body": {
        "itemId": "${itemId}",
        "note": "${note}"
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID",
          "type": "string"
        },
        "itemId": {
          "required": true,
          "description": "Quote item ID",
          "type": "string"
        },
        "note": {
          "required": true,
          "description": "Note text",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote item-note admin",
      "method": "PUT",
      "endpoint": "/V1/amasty_quote/quote_item/note/admin/:quoteId",
      "description": "Add or update an admin note on a quote item",
      "body": {
        "itemId": "${itemId}",
        "note": "${note}"
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote ID",
          "type": "string"
        },
        "itemId": {
          "required": true,
          "description": "Quote item ID",
          "type": "string"
        },
        "note": {
          "required": true,
          "description": "Note text",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty quote cart get",
      "method": "GET",
      "endpoint": "/V1/quote-carts/:quoteId",
      "description": "Get a quote cart by ID (admin)",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote cart ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart create",
      "method": "POST",
      "endpoint": "/V1/quote-carts",
      "description": "Create a new quote cart (admin)",
      "options": {
        "customerId": {
          "required": false,
          "description": "Customer ID to create the quote cart for",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart update",
      "method": "PUT",
      "endpoint": "/V1/quote-carts/:quoteId",
      "description": "Update a quote cart (admin)",
      "body": {
        "customer_note": "${customer_note}"
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote cart ID",
          "type": "string"
        },
        "customer_note": {
          "required": false,
          "description": "Customer-facing note on the quote cart",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart cancel",
      "method": "PUT",
      "endpoint": "/V1/quote-carts/:quoteId/cancel",
      "description": "Cancel a quote cart (admin)",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote cart ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart create-for-customer",
      "method": "POST",
      "endpoint": "/V1/customers/:customerId/quote-carts",
      "description": "Create a quote cart for a specific customer (admin)",
      "options": {
        "customerId": {
          "required": true,
          "description": "Customer ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart get-mine",
      "method": "GET",
      "endpoint": "/V1/quote-carts/mine",
      "description": "Get the current customer's quote cart"
    },
    {
      "name": "amasty quote cart create-mine",
      "method": "POST",
      "endpoint": "/V1/quote-carts/mine",
      "description": "Create a quote cart for the current customer"
    },
    {
      "name": "amasty quote cart submit-mine",
      "method": "PUT",
      "endpoint": "/V1/quote-carts/mine/submit",
      "description": "Submit the current customer's quote for review"
    },
    {
      "name": "amasty quote cart clear-mine",
      "method": "DELETE",
      "endpoint": "/V1/quote-carts/mine/clear",
      "description": "Clear all items from the current customer's quote cart"
    },
    {
      "name": "amasty quote cart remove-from-cart",
      "method": "DELETE",
      "endpoint": "/V1/quote-carts/mine/remove-from-cart",
      "description": "Remove the active quote from the current shopping cart"
    },
    {
      "name": "amasty quote cart update-note",
      "method": "PUT",
      "endpoint": "/V1/quote-carts/mine/update-customer-note",
      "description": "Update the customer note on the current quote cart",
      "body": {
        "note": "${note}"
      },
      "options": {
        "note": {
          "required": true,
          "description": "Customer note text",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart move-to-cart",
      "method": "PUT",
      "endpoint": "/V1/quote-carts/:quoteId/in-cart",
      "description": "Move an approved quote back into the shopping cart",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote cart ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart in-quote",
      "method": "POST",
      "endpoint": "/V1/quote-carts/mine/in-quote",
      "description": "Move items from the shopping cart into the current quote cart"
    },
    {
      "name": "amasty quote cart cancel-mine",
      "method": "PUT",
      "endpoint": "/V1/customers/quote-carts/:quoteId/cancel",
      "description": "Cancel the current customer's quote",
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote cart ID",
          "type": "string"
        }
      }
    },
    {
      "name": "amasty quote cart shipping",
      "method": "POST",
      "endpoint": "/V1/quote-carts/:quoteId/shipping-information",
      "description": "Set shipping information on a quote cart",
      "body": {
        "addressInformation": {
          "shipping_carrier_code": "${shipping_carrier_code}",
          "shipping_method_code": "${shipping_method_code}"
        }
      },
      "options": {
        "quoteId": {
          "required": true,
          "description": "Quote cart ID",
          "type": "string"
        },
        "shipping_carrier_code": {
          "required": true,
          "description": "Shipping carrier code (e.g. flatrate)",
          "type": "string"
        },
        "shipping_method_code": {
          "required": true,
          "description": "Shipping method code (e.g. flatrate)",
          "type": "string"
        }
      }
    },

    {
      "name": "amasty quote cart items list-mine",
      "method": "GET",
